// prisma/schema.prisma
// Spanish learning app (callao384). Adapted from naxuexi's live schema.
// Removed: Poem, PoemProgress, ConversationSession, PendingVocab.
// Word: hanzi->word, +gender, dropped pinyin/hskLevel/components/audioUrl.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Word {
  id           Int                 @id @default(autoincrement())
  word         String              @unique
  meaning      String
  gender       String?             // "M" | "F" | null (verbs, adjectives, etc.)
  category     String?
  mnemonic     String?
  status       String              @default("NEW") // "NEW" | "LEARNING" | "LEARNED"
  easeFactor   Float               @default(2.5)
  interval     Int                 @default(1)
  nextReview   DateTime            @default(now())
  reviewCount  Int                 @default(0)
  correctCount Int                 @default(0)
  focusReview  Boolean             @default(false)
  reviewLogs   ReviewLog[]
  dailyWords   DailyPracticeWord[]
  masteries    WordMastery[]
}

model ReviewLog {
  id        Int      @id @default(autoincrement())
  wordId    Int
  word      Word     @relation(fields: [wordId], references: [id])
  module    String   // "flashcard" | "recognize" | "produce" | etc.
  result    String   // "correct" | "incorrect" | "hard"
  timestamp DateTime @default(now())
}

model DailyPractice {
  id        Int                 @id @default(autoincrement())
  date      DateTime            @unique
  sentVia   String              @default("telegram")
  completed Boolean             @default(false)
  words     DailyPracticeWord[]
}

model DailyPracticeWord {
  id               Int           @id @default(autoincrement())
  dailyPracticeId  Int
  dailyPractice    DailyPractice @relation(fields: [dailyPracticeId], references: [id])
  wordId           Int
  word             Word          @relation(fields: [wordId], references: [id])
  practiced        Boolean       @default(false)
}

model Setting {
  key   String @id
  value String
}

// ─── Skill-specific mastery tracking ────────────────────────────────────────

model WordMastery {
  id           Int      @id @default(autoincrement())
  wordId       Int
  word         Word     @relation(fields: [wordId], references: [id])
  skill        String   // "RECOGNIZE" (ES->EN) | "PRODUCE" (EN->ES)
  easeFactor   Float    @default(2.5)
  interval     Int      @default(1)
  nextReview   DateTime @default(now())
  status       String   @default("NEW") // "NEW" | "LEARNING" | "LEARNED"
  reviewCount  Int      @default(0)
  correctCount Int      @default(0)

  @@unique([wordId, skill])
}

// ─── Translation exercise models ─────────────────────────────────────────────

model TranslationSentence {
  id        Int                  @id @default(autoincrement())
  direction String               // "ES_TO_EN" | "EN_TO_ES"
  prompt    String               // sentence to translate
  reference String               // expected translation
  usedWords String               // JSON array of words used
  used      Boolean              @default(false)
  createdAt DateTime             @default(now())
  attempts  TranslationAttempt[]
}

model TranslationAttempt {
  id         Int                 @id @default(autoincrement())
  sentenceId Int
  sentence   TranslationSentence @relation(fields: [sentenceId], references: [id])
  userAnswer String
  score      Float               // 0.0 - 1.0
  feedback   String              // Claude's feedback
  passed     Boolean
  createdAt  DateTime            @default(now())
}
